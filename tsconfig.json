{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "esModuleInterop": false,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      /** Allow referencing the `src` directory as @ */
      "@/*": ["./src/*"],
      /** Map "addons" alias in Three.js so that imports are typed */
      "three/addons/*": ["./node_modules/@types/three/examples/jsm/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
